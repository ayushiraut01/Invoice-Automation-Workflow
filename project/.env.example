# =========================================================
# GEMINI (AI EXTRACTION) — Claude API is NOT used in this project
# =========================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=3
GEMINI_TEMPERATURE=0.1

# =========================================================
# AIRTABLE
# =========================================================
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_INVOICES=Invoices
AIRTABLE_TABLE_VENDORS=Vendors
AIRTABLE_TABLE_DEPARTMENTS=Departments
AIRTABLE_TABLE_AUDIT=AuditTrail
AIRTABLE_TABLE_ERRORS=DeadLetterQueue

# =========================================================
# INBOUND EMAIL (IMAP) — invoice intake mailbox
# =========================================================
IMAP_HOST=imap.yourprovider.com
IMAP_PORT=993
IMAP_USER=invoices@yourcompany.com
IMAP_PASSWORD=your_imap_app_password
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# =========================================================
# OUTBOUND EMAIL (SMTP) — approvals & notifications
# =========================================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=ap-automation@yourcompany.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_NAME=AP Invoice Automation
SMTP_FROM_EMAIL=ap-automation@yourcompany.com
AP_TEAM_ALERT_EMAIL=ap-team@yourcompany.com

# =========================================================
# GOOGLE DRIVE (PDF STORAGE)
# =========================================================
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_DRIVE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=your_service_account_private_key

# =========================================================
# WEBHOOK / APPROVAL LINKS
# =========================================================
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
APPROVAL_LINK_SECRET=change_me_to_a_long_random_string
APPROVAL_LINK_TTL_HOURS=72

# =========================================================
# GENERAL / OPS
# =========================================================
NODE_ENV=production
LOG_LEVEL=info
MAX_PDF_SIZE_MB=15
DUPLICATE_CHECK_LOOKBACK_DAYS=365
DEFAULT_CONFIDENCE_REVIEW_THRESHOLD=0.75
